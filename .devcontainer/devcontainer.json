{
  "name": "hydrangea-compiler",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "haskell.haskell"
      ]
    }
  },
  "postCreateCommand": "cabal update && .devcontainer/install-hydrangea-vscode-extension.sh --prepare-only",
  "postAttachCommand": ".devcontainer/install-hydrangea-vscode-extension.sh",
  "remoteUser": "root"
}
