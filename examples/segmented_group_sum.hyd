let offsets =
  generate [5] (let f [i] =
    if i = 0 then 0 else
    if i = 1 then 2 else
    if i = 2 then 5 else
    if i = 3 then 5 else 7 in f)

let vals =
  generate [7] (let f [i] =
    if i = 0 then 1 else
    if i = 1 then 2 else
    if i = 2 then 10 else
    if i = 3 then 20 else
    if i = 4 then 30 else
    if i = 5 then 7 else 8 in f)

let main = segmented_reduce (let add acc x = acc + x in add) 0 offsets vals
