let n = 8
let h0 = fill [4] 0
let src1 = generate [n] (let f [i] = i / 2 in f)
let vals1 = generate [n] (let f [i] = 1 in f)
let src2 = generate [n] (let f [i] = (n - 1 - i) / 2 in f)
let vals2 = generate [n] (let f [i] = 1 in f)
let h1 = scatter (+) h0 src1 vals1
let main = scatter (+) h1 src2 vals2
