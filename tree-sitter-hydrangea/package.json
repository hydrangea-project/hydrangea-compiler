{
  "name": "tree-sitter-hydrangea",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Hydrangea language.",
  "license": "BSD-3-Clause",
  "files": [
    "editors/**",
    "grammar.js",
    "queries/**",
    "src/**",
    "test/**",
    "tree-sitter.json"
  ],
  "scripts": {
    "generate": "tree-sitter generate",
    "build:wasm": "tree-sitter build --wasm -o dist/tree-sitter-hydrangea.wasm .",
    "test": "tree-sitter test",
    "parse:examples": "tree-sitter parse ../examples/simple.hyd ../examples/mat_mul.hyd ../examples/stencil_2d.hyd"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.7"
  },
  "tree-sitter": [
    {
      "scope": "source.hydrangea",
      "file-types": [
        "hyd"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}
